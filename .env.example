# TeamFrame environment template
# Copy to .env.local for development. Never commit real values.

# --- Supabase (client-safe) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- App URL ---
# Local dev example: http://localhost:3030
# Production example: https://your-domain.com
SITE_URL=

# --- Supabase (server-only) ---
# Service role key. Must NEVER be exposed to the browser or imported in client code.
SUPABASE_SERVICE_ROLE_KEY=

# CI-only service role key (must come from a separate CI Supabase project).
SUPABASE_SERVICE_ROLE_KEY_CI=

# Postgres connection string for db scripts.
# Prefer the Supabase Session pooler URI (port 5432) for long-lived script workloads.
# Transaction pooler mode (6543) is intended for short-lived stateless workloads
# and can break session-level behavior used by migration and reliability scripts.
# db:reset safety toggles:
# ALLOW_DESTRUCTIVE_RESET=true
# ALLOW_DESTRUCTIVE_RESET_IN_CI=true
# PROTECTED_DB_HOST_TOKENS=prod,production,live
# Example:
# postgresql://postgres.<project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# CI-only Postgres URL (must come from a separate CI Supabase project).
SUPABASE_DB_URL_CI=

# --- OpenAI (server-only) ---
# Used exclusively by /lib/ai for generateBio and generateContract.
OPENAI_API_KEY=

# --- Supabase Management API (optional, server-only) ---
# Personal Access Token for the Supabase Management API.
# Used by `npm run auth:lock` to enforce the magic-link-only contract on the
# Supabase project. Create one at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
