# TeamFrame Staging Environment
# Copy this file to .env.staging and fill in real values from the teamframe-staging Supabase project.
# .env.staging is git-ignored. Never commit real credentials.
# See docs/launch/environment-parity.md for setup instructions.

# Supabase project URL — must differ from NEXT_PUBLIC_SUPABASE_URL (existing project).
SUPABASE_URL_STAGING=

# Anon key — safe to use in client-side code (RLS enforced).
SUPABASE_ANON_KEY_STAGING=

# Service role key — bypasses RLS. Use only for seeding/migrations, never for user queries.
SUPABASE_SERVICE_ROLE_KEY_STAGING=

# Direct Postgres connection string — used by schema migration scripts.
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL_STAGING=
