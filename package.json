{
  "name": "teamframe",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight HR structure system for startups with 6-25 employees. Installs in 48-72 hours.",
  "license": "MIT",
  "scripts": {
    "dev": "next dev -p 3030",
    "build": "next build",
    "start": "next start",
    "env:check": "node scripts/validate-env.mjs build",
    "env:check:smoke": "node scripts/validate-env.mjs smoke",
    "env:check:db": "node scripts/validate-env.mjs db",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:apply": "node scripts/apply-schemas.mjs",
    "db:reset": "node scripts/reset-and-apply.mjs",
    "db:inspect": "node scripts/inspect-db.mjs",
    "setup:staging": "node scripts/setup-staging-project.mjs",
    "db:apply:staging": "node scripts/apply-schemas-staging.mjs",
    "db:reset:staging": "node scripts/reset-and-apply-staging.mjs --allow-destructive-reset",
    "verify:parity": "node scripts/verify-parity.mjs",
    "verify:rls": "node scripts/verify-rls.mjs",
    "seed:admin": "node scripts/seed-admin.mjs",
    "storage:setup": "node scripts/setup-storage.mjs",
    "smoke:core-loop": "node scripts/smoke-core-loop.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.1.0",
    "pg": "^8.21.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
